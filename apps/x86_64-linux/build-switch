#!/bin/sh -e

RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Parse arguments for --host parameter
HOST=""
OTHER_ARGS=""

while [ $# -gt 0 ]; do
  case "$1" in
    --host=*)
      HOST="${1#*=}"
      shift
      ;;
    --host)
      HOST="$2"
      shift 2
      ;;
    *)
      OTHER_ARGS="$OTHER_ARGS $1"
      shift
      ;;
  esac
done

# Map the machine architecture to its platform-generic flake target.
arch_target() {
  SYSTEM=$(uname -m)
  case "$SYSTEM" in
    x86_64)  echo "x86_64-linux" ;;
    aarch64) echo "aarch64-linux" ;;
    *)
      echo -e "${RED}Unsupported architecture: $SYSTEM${NC}" >&2
      exit 1
      ;;
  esac
}

if [ -n "$HOST" ]; then
  # Explicit override always wins.
  FLAKE_TARGET="$HOST"
  echo -e "${YELLOW}Building for named host: $HOST${NC}"
else
  # No override: prefer a named config matching this machine's hostname
  # (e.g. garfield, odie), otherwise fall back to the platform-generic config.
  HOSTNAME=$(hostname -s 2>/dev/null || hostname)
  CONFIGS=$(nix eval --raw .#nixosConfigurations \
    --apply 'cfgs: builtins.concatStringsSep " " (builtins.attrNames cfgs)' 2>/dev/null)

  case " $CONFIGS " in
    *" $HOSTNAME "*)
      FLAKE_TARGET="$HOSTNAME"
      echo -e "${YELLOW}Building for named host: $HOSTNAME${NC}"
      ;;
    *)
      FLAKE_TARGET=$(arch_target)
      echo -e "${YELLOW}Building for platform: $FLAKE_TARGET${NC}"
      ;;
  esac
fi

echo -e "${YELLOW}Starting...${NC}"

# We pass SSH from user to root so root can download secrets from our private Github
sudo /run/current-system/sw/bin/nixos-rebuild switch --flake .#$FLAKE_TARGET $OTHER_ARGS

echo -e "${GREEN}Switch to new generation complete!${NC}"
