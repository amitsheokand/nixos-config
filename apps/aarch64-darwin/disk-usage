#!/bin/sh -e

RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "${CYAN}=== Nix store & disk usage ===${NC}"
echo ""
echo -e "${YELLOW}Nix store size:${NC}"
du -sh /nix/store 2>/dev/null || echo "  (cannot read)"
echo ""
echo -e "${YELLOW}Disk usage:${NC}"
df -h /nix / 2>/dev/null | sed 's/^/  /'
echo ""

echo -e "${YELLOW}System generations (darwin-rebuild):${NC}"
darwin-rebuild --list-generations 2>/dev/null || true
echo ""

echo -e "${YELLOW}If you ran clean (delete-older-than 1d), would remove:${NC}"
sudo nix-collect-garbage --delete-older-than 1d --dry-run 2>/dev/null || echo "  (run with sudo to see)"
echo ""

echo -e "${YELLOW}Temp & cache (approximate):${NC}"
for d in /tmp "$HOME/.cache" "$HOME/.local/share/nix"; do
  [ -d "$d" ] && echo "  $d: $(du -sh "$d" 2>/dev/null | cut -f1)"
done
echo ""

echo -e "${GREEN}To reclaim space: nix run .#clean${NC}"
